# Host port the container binds to.
PORT=3000

# ─── AI features (OpenRouter) ────────────────────────────────────────────────
# Every AI feature — "Generate cards", "Generate study text", in-card "AI chat",
# and card "Infographics" — runs through a single OpenRouter API key. The rest
# of the app (study, review, progress, notes, search) works with no key set.
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default models. Per-feature model pickers in the UI
# let you switch models at request time; these set the server-side fallback
# used when the UI doesn't send one. Values are OpenRouter model slugs.
# OPENROUTER_MODEL=openai/gpt-5.4
# OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2

# Optional: your app URL, sent as the HTTP-Referer for OpenRouter attribution.
# OPENROUTER_SITE_URL=https://your-deployment.example.com
