# Host port the container binds to.
PORT=3000

# LLM provider for the "Generate cards / Generate study text / AI chat"
# features. Leave all of this blank to run the app in pure offline-flashcard
# mode — core study, reviews, progress, notes, and search all work without a
# key. Pick ONE provider and set the matching key + optional model override.

# openai | anthropic | google
LLM_PROVIDER=

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash
