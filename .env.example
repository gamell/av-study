# Host port the container binds to.
PORT=3000

# ─── AI features ─────────────────────────────────────────────────────────────
# The "Generate cards", "Generate study text", "AI chat", and "Generate
# infographic" features call out to AI providers. The rest of the app (study,
# review, progress, notes, search) works completely without any of this set.
#
# Providing ANY ONE of the three API keys below is enough. Setting multiple
# turns on automatic fallback: if a provider's call fails (rate limit, 5xx,
# bad model id, missing key) the chain moves to the next attempt.
#
# Each provider has TWO model slots — a primary and a fallback — so you also
# get per-provider fallback before crossing over to a different provider.
#
# Default chain order (highest first):
#   1. Anthropic primary  — Claude Opus 4.6 (adaptive thinking, max effort)
#   2. Anthropic fallback — Claude Opus 4.5
#   3. OpenAI primary     — GPT-5.5
#   4. OpenAI fallback    — GPT-5.4
#   5. Google primary     — Gemini 3.1 Pro (preview)
#   6. Google fallback    — Gemini 2.5 Pro (stable)
#
# Override the starting provider with LLM_PROVIDER (the others stay in the
# chain as fallbacks).

# anthropic | openai | google | (unset = use priority above)
LLM_PROVIDER=

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MODEL_FALLBACK=claude-opus-4-5-20251101

# ─── OpenAI (GPT + image generation) ───────────────────────────────────────
# OPENAI_API_KEY is also used for per-card infographics via gpt-image-2.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# OPENAI_MODEL_FALLBACK=gpt-5.4

# ─── Google (Gemini) ────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-3.1-pro-preview
# GOOGLE_MODEL_FALLBACK=gemini-2.5-pro
